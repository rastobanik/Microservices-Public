{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=onlinecoursedatabase;Username=myuser;Password=mypassword"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ProductClient": {
    "BaseAddress": "http://localhost:5037"
  },
  "Redis": {
    "Configuration": "localhost",
    "ConnectRetry": "4",
    "ReconnectTimeOut": "6000"
  },
  "RequestLogging": {
    "SlowRequestThresholdMs": 1000,
    "NoisePaths": [ "/swagger", "/health", "/favicon" ]
  },
  "RateLimiting": {
    "Global": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 2
    },
    "Fixed": {
      "PermitLimit": 4,
      "WindowSeconds": 30,
      "QueueLimit": 5
    }
  },
  "Serilog": {
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithClientIp"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Warning"
      }
    },
    "Properties": {
      "Application": "OrderServiceProject"
    },
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq",
      "Serilog.Enrichers.ClientInfo"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  }
}
